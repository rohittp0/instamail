# Copy to .env (gitignored). The CLI loads it at startup; providers are env-gated.
# A credential being present is consent to use that provider, in FREE -> OFFICIAL -> PAID order.
# Paid providers run only as a last resort, after free ones come up empty.

# --- FREE (optional booster for the public Instagram path) ---
# Browser sessionid cookie; sharply reduces 401s and raises the fetch rate. No key still works.
INSTAGRAM_SESSIONID=

# --- FREE-with-key (Google Programmable Search, 100 queries/day free) ---
# Full-text site:instagram.com discovery; preferred over topsearch/DDG when set.
# Create an API key + a Programmable Search Engine (its "Search engine ID" = cx).
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- OFFICIAL (Meta Graph API: Hashtag Search + Business Discovery) ---
# Requires an IG professional account + a reviewed Meta app. No per-call charge.
META_ACCESS_TOKEN=
META_IG_USER_ID=

# --- PAID (last resort) ---
# Vendor discovery/enrichment (Bright Data). Costs money.
BRIGHTDATA_API_KEY=
# Alternative vendor token (Apify), if you wire it instead.
APIFY_TOKEN=
# Hunter email finder (company-domain emails). Costs money.
HUNTER_API_KEY=
