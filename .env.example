# InstaMail environment template. Copy to `.env` and fill in values:
#   cp .env.example .env
# The CLI loads `.env` automatically at startup (python-dotenv), making these
# variables available to every plugin. `.env` is gitignored; never commit secrets.

# Instagram session cookie ('sessionid') — sharply reduces 401s and lets the harvester
# fetch faster. Copy the 'sessionid' cookie value from a logged-in instagram.com browser session.
INSTAGRAM_SESSIONID=
