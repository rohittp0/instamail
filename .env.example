# InstaMail environment template. Copy to `.env` and fill in values:
#   cp .env.example .env
# The CLI loads `.env` automatically at startup (python-dotenv), making these
# variables available to every plugin. `.env` is gitignored; never commit secrets.

# Instagram session cookie ('sessionid'). Powers the high-confidence resolution steps:
#   - contact-import (address_book/link) REQUIRES it — email->handle direct match,
#   - users/lookup obfuscated-email verification and profile harvesting become reliable,
#   - throughput rises (~5s vs ~18s min interval) and 401s drop.
# Its numeric prefix is the account id. Use a throwaway/OSINT account: contact-import uploads
# a contact from it. Copy the 'sessionid' cookie from a logged-in instagram.com browser session.
# NOTE: the sensitive endpoints are blocked from datacenter IPs even with this set — run from
# a residential/mobile IP. `.env` is gitignored; never commit it.
INSTAGRAM_SESSIONID=
