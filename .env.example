# Copy to .env (gitignored). The scripts load it at startup via python-dotenv.

# --- Google Sheets (required) ---
# The spreadsheet that holds the dump / input / output tabs.
GOOGLE_SHEETS_SPREADSHEET_ID=
# The service-account key JSON, BASE64-ENCODED (the file content itself, not a path).
#   base64 -i service-account.json | tr -d '\n'
# Share the spreadsheet with the service account's client_email once.
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Instagram stats (optional booster) ---
# Browser sessionid cookie; reduces 401s on the public web_profile_info path and raises the fetch
# rate. The stats script still runs without it (more handles come back as stats_status=blocked).
INSTAGRAM_SESSIONID=
